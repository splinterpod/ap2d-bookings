// Kherani Lab Instrument Booking System — data model
// All timestamps stored in UTC; display timezone handled in app (America/Toronto).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [btree_gist]
}

enum Role {
  MEMBER
  ADMIN
  GUEST
}

enum UserStatus {
  PENDING
  ACTIVE
  DEACTIVATED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}

enum LaserPhase {
  SIGN_IN
  SIGN_OUT
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CLAIMED
  EXPIRED
}

model LabSettings {
  id        Int      @id @default(1)
  timezone  String   @default("America/Toronto")
  labName   String   @default("Kherani Lab")
  updatedAt DateTime @updatedAt
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  passwordHash String
  role         Role       @default(MEMBER)
  status       UserStatus @default(PENDING)
  guestExpiresAt DateTime?

  // Notification preferences
  notifyConfirmations Boolean @default(true)
  notifyReminders     Boolean @default(true)

  // Per-user overrides (null = fall back to instrument/global default)
  // Standard-hours weekly limit in minutes. null = use instrument default. -1 sentinel = unlimited.
  standardHoursWeeklyLimitMinutes Int?
  // Tri-state booking approval override. null = use instrument default.
  requiresBookingApproval Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings          Booking[]
  trainings         InstrumentTraining[]
  trainingsGranted  InstrumentTraining[] @relation("TrainedByAdmin")
  authSessions      AuthSession[]
  passwordResets    PasswordResetToken[]
  instrumentSessions InstrumentSession[]
  waitlistEntries   WaitlistEntry[]
  auditEvents       AuditEvent[]         @relation("AuditActor")
  instrumentLimits  UserInstrumentLimit[]
}

model Instrument {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  location    String
  description String?
  // "raman" for the v1 pilot; enables Raman-specific session form.
  instrumentType String @default("raman")

  maintenance Boolean @default(false)

  // Booking rules
  slotMinutes          Int  @default(30)
  maxSessionMinutes    Int  @default(240)
  advanceBookingDays   Int  @default(14)
  minNoticeMinutes     Int  @default(0)
  // Minimum idle time between the same user's bookings on this instrument (prevents hoarding via small gaps).
  minGapBetweenUserBookingsMinutes Int @default(240)
  cancellationCutoffMinutes Int @default(0)

  // Session reminders & no-show handling
  lateSignInReminderMinutes Int @default(15)
  noShowCancelMinutes       Int @default(30)

  // Standard hours window (days are 1=Mon..7=Sun, times are "HH:mm" in app timezone)
  standardHours Json @default("{\"days\":[1,2,3,4,5],\"start\":\"09:00\",\"end\":\"17:00\"}")
  // Weekly caps in minutes. null = unlimited.
  standardHoursWeeklyLimitMinutes Int? @default(720)
  afterHoursWeeklyLimitMinutes    Int?

  // Approval defaults
  defaultRequiresApproval Boolean @default(false)
  autoConfirmIfTrained    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  trainings InstrumentTraining[]
  waitlist  WaitlistEntry[]
  userLimits UserInstrumentLimit[]
}

model UserInstrumentLimit {
  id           String @id @default(cuid())
  userId       String
  instrumentId String
  // null = use instrument default. -1 = unlimited. positive = custom minutes.
  standardHoursWeeklyLimitMinutes Int?
  // null = use instrument default.
  requiresBookingApproval Boolean?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([userId, instrumentId])
}

model InstrumentTraining {
  id           String   @id @default(cuid())
  userId       String
  instrumentId String
  trainedAt    DateTime @default(now())
  trainedByAdminId String?

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument     Instrument  @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  trainedByAdmin User?       @relation("TrainedByAdmin", fields: [trainedByAdminId], references: [id], onDelete: SetNull)

  @@unique([userId, instrumentId])
}

model Booking {
  id           String        @id @default(cuid())
  instrumentId String
  userId       String
  startAt      DateTime
  endAt        DateTime
  // Original booked end; endAt may be shortened early on sign-out to free the calendar slot.
  scheduledEndAt DateTime
  status       BookingStatus @default(CONFIRMED)
  notes        String?
  noShow       Boolean       @default(false)

  reminder1Sent  Boolean @default(false)
  lateSignInReminderSent Boolean @default(false)
  autoSignedOutNotified  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instrument Instrument         @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    InstrumentSession?

  @@index([instrumentId, startAt])
  @@index([userId, startAt])
  @@index([status])
}

model InstrumentSession {
  id        String   @id @default(cuid())
  bookingId String   @unique
  userId    String

  signedInAt  DateTime  @default(now())
  signedOutAt DateTime?
  // When the instrument was truly freed (defaults to signedOutAt; may exceed booking end on overrun).
  actualEndAt DateTime?

  // Laser power handoff
  laserTurnedOn  Boolean @default(false)
  laserAlreadyOn Boolean @default(false)

  // Skip tracking (audit)
  signInSkipped  Boolean @default(false)
  signOutSkipped Boolean @default(false)

  // Flagged when the next user signs in before this session was signed out.
  unsignedOut Boolean @default(false)

  notes String?

  booking  Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  readings SessionLaserReading[]

  @@index([userId])
  @@index([signedOutAt])
}

model SessionLaserReading {
  id          String     @id @default(cuid())
  sessionId   String
  wavelengthNm Int       // 532 | 633 | 785
  calibrated  Boolean    @default(false)
  photonCount Float?
  phase       LaserPhase

  session InstrumentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model AuthSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WaitlistEntry {
  id           String         @id @default(cuid())
  instrumentId String
  userId       String
  startAt      DateTime
  endAt        DateTime
  status       WaitlistStatus @default(WAITING)
  notifiedAt   DateTime?
  holdExpiresAt DateTime?
  createdAt    DateTime       @default(now())

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([instrumentId, startAt])
  @@index([status])
}

model AuditEvent {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
