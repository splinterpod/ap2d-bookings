# --- Database (PostgreSQL) ---
# Local (docker-compose): postgres://ap2d:ap2d@localhost:5432/ap2d
# Neon: postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgres://ap2d:ap2d@localhost:5432/ap2d"

# --- App ---
# Public base URL (used in emails + links). No trailing slash.
APP_URL="http://localhost:3000"
# Display timezone for all booking rules and UI.
APP_TIMEZONE="America/Toronto"

# --- First admin bootstrap (seed) ---
# A pending-or-active admin account is created on seed if none exists.
SEED_ADMIN_EMAIL="1auqilsha@gmail.com"
SEED_ADMIN_USERNAME="admin"
# Temporary password for the seeded admin. Change after first login.
SEED_ADMIN_PASSWORD="ChangeMe!2026"

# --- Email (Resend) ---
# Leave RESEND_API_KEY empty in dev to log emails to the console instead of sending.
RESEND_API_KEY=""
EMAIL_FROM="BenchTime <bookings@ap2d.ca>"

# --- Account owner (only this email may promote/delete admins) ---
ACCOUNT_OWNER_EMAIL="1auqilsha@gmail.com"

# --- Cron protection ---
# Shared secret required to call /api/cron (Vercel Cron sets this as a Bearer token).
CRON_SECRET="change-me-to-a-long-random-string"
