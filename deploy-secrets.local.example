# Copy to deploy-secrets.local and fill in real values.
# deploy-secrets.local is gitignored — never commit it.

# --- Neon PostgreSQL ---
# Direct (migrations / local CLI):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Pooled (use on Vercel / serverless — hostname contains -pooler):
DATABASE_URL_POOLED="postgresql://USER:PASSWORD@HOST-pooler/neondb?sslmode=require"

# --- Vercel env vars (Production) ---
APP_URL="https://your-domain.example"
APP_TIMEZONE="America/Toronto"
ACCOUNT_OWNER_EMAIL="owner@example.com"
EMAIL_FROM="BenchTime <bookings@your-domain.example>"
CRON_SECRET="generate-a-long-random-string"
RESEND_API_KEY="re_..."

# --- Bootstrap admin (seed only — change password after first login) ---
SEED_ADMIN_EMAIL="owner@example.com"
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="ChangeMe!2026"

# --- External cron (e.g. cron-job.org every 15 min) ---
# URL: https://your-domain.example/api/cron
# Header: Authorization: Bearer <CRON_SECRET>
